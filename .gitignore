# =============================================
# BeconAI .gitignore
# =============================================

# Documentation (generated, not tracked in VCS)
docs/

# Dependencies
node_modules/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual Environments
venv/
env/
.venv/
.env/

# Environment Variables
.env
.env.local
.env.*.local

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS Files
Thumbs.db
.DS_Store
Desktop.ini
ehthumbs.db

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build Outputs
dist/
build/
out/
.next/
.nuxt/
dist-ssr
.output
.vinxi
.tanstack/**
.nitro

# Coverage
coverage/
.nyc_output/
htmlcov/

# Temporary Files
*.tmp
*.temp
.cache/
.parcel-cache/

# Python Specific
*.so
*.dylib
.Python
pip-log.txt
pip-delete-this-directory.txt

# Database
*.db
*.sqlite3
*.sqlite

# Secrets
*.pem
*.key
*.cert

# Wrangler / Cloudflare
.wrangler/
.dev.vars
